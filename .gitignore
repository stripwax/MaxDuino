# no PlatformIO temporary files
.pio

# No local files/preferences/etc from Visual Studio Code
.vscode/*

# No precompiled Python (we use some .py scripts)
**/*.pyc

# Temporary file created by PlatformIO when building Arduino projects (the main .ino is converted to a single .cpp during build)
MaxDuino.ino.cpp

idf_component.yml

# object files for compilation output
**/*.o
cli/build

# "test" inputs and outputs are now in a separate branch, so 'hide' them via .gitignore
test/inputs
test/outputs
test/gen-outputs
# "testing" folder is where the github action has been setup to run; if you run it locally you end up with copies of stuff in that folder, don't commit those to git!
testing/
# coverage files generated by coverage testing
*.gcov